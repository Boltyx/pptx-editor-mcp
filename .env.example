# Copy this file to .env and fill in the values.

# Port the MCP server listens on inside (and exposed from) the container.
MCP_PORT=8015

# Absolute or relative path to the folder the MCP server is allowed to access.
# Only files inside this folder will be reachable inside the container.
PPTX_DIR=./pptx-files

# Bearer token clients must send as "Authorization: Bearer <token>".
# Leave unset to run unauthenticated (not recommended for public exposure).
MCP_AUTH_TOKEN=your-secret-token-here

# --- Ngrok mode only ---
# Get your token at https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=your_ngrok_authtoken_here
